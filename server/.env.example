# Conexão com o Postgres (use a sua; NÃO comite a real)
DATABASE_URL=postgres://usuario:senha@host:5432/banco?sslmode=require

# Schema isolado onde o app cria as tabelas (não toca no resto do banco)
DB_SCHEMA=financeiro_casal

# Segredo para assinar os tokens de sessão (gere um aleatório e mantenha fixo)
# Ex.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque-isto-por-um-segredo-aleatorio-longo

# Porta do servidor
PORT=8787

# (Opcional) restringe o CORS ao domínio do app, separado por vírgula
# ALLOWED_ORIGIN=https://casal.seudominio.com

# --- Notificações push (Web Push / VAPID) ---
# Se não definir, o servidor gera e guarda as chaves no banco (turnkey).
# Para gerar você mesmo: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:voce@seudominio.com
# Fuso e hora local do resumo diário (padrão: America/Sao_Paulo às 8h)
# APP_TZ=America/Sao_Paulo
# DIGEST_HOUR=8

# --- IA (OpenRouter) ---
# Pegue sua chave em https://openrouter.ai/keys  (sem ela, a IA fica desligada e o app segue normal)
# OPENROUTER_API_KEY=sk-or-v1-...
# Modelo (qualquer um do OpenRouter). Padrão: openai/gpt-4o-mini
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_REFERER=https://casal.seudominio.com
